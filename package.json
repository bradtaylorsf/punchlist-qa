{
  "name": "punchlist-qa",
  "version": "0.2.0",
  "description": "Standalone QA testing dashboard and support widget toolkit for any project",
  "license": "MIT",
  "author": "Brad Taylor <brad@bradtaylorsf.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bradtaylorsf/punchlist-qa.git"
  },
  "keywords": [
    "qa",
    "testing",
    "support",
    "github-issues",
    "jira",
    "linear",
    "quality-assurance"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "punchlist-qa": "./bin/punchlist.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "punchlist.config.example.json"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build && pnpm test && pnpm type-check",
    "build": "tsc && node scripts/build-widget.mjs && vite build --config src/dashboard/vite.config.ts",
    "build:widget": "node scripts/build-widget.mjs",
    "build:dashboard": "vite build --config src/dashboard/vite.config.ts",
    "dev": "node scripts/build-widget.mjs && concurrently -k -n api,dashboard -c green,yellow \"tsx watch scripts/dev-server.ts\" \"vite --config src/dashboard/vite.config.ts\"",
    "dev:api": "tsx watch scripts/dev-server.ts",
    "dev:dashboard": "vite --config src/dashboard/vite.config.ts",
    "demo": "node scripts/demo.mjs",
    "cli": "node bin/punchlist.mjs",
    "start": "node bin/punchlist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.dashboard.json",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "connect-pg-simple": "^10.0.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "memorystore": "^1.6.7",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
