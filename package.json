{
  "name": "punchlist-qa",
  "version": "0.1.0",
  "description": "Standalone QA testing dashboard and support widget toolkit for any project",
  "license": "MIT",
  "author": "Brad Taylor <brad@bradtaylorsf.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bradtaylorsf/punchlist-qa.git"
  },
  "keywords": [
    "qa",
    "testing",
    "support",
    "github-issues",
    "jira",
    "linear",
    "quality-assurance"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "punchlist-qa": "./bin/punchlist.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "punchlist.config.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "cli": "node bin/punchlist.mjs",
    "start": "node bin/punchlist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
